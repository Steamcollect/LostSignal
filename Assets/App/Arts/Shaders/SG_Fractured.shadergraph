{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "0e1cf92c1888438abbde0c1fa6486252",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "CustomVoronoi (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -811.0,
            "y": 201.0,
            "width": 244.0,
            "height": 326.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "b4b0f0650a224a69a4f681bec32b5beb"
        },
        {
            "m_Id": "00c1c313ecc5459d8eca045724f6d1da"
        },
        {
            "m_Id": "11591eafe0e34cd5a4aa16b8c41c1b53"
        },
        {
            "m_Id": "28ea6f0a8e32426daec64fe0726312f0"
        },
        {
            "m_Id": "38e965d97b37492eb2a0755d1ebbbfc9"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "CustomVoronoi",
    "m_FunctionSource": "1a498de153b7dc14380ee55e8a55fb8d",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "inline float2 randomVector (float2 UV, float offset)\r\n{\r\n    float2x2 m = float2x2(15.27, 47.63, 99.41, 89.98);\r\n    UV = frac(sin(mul(UV, m)) * 46839.32);\r\n    return float2(sin(UV.y*+offset)*0.5+0.5, cos(UV.x*offset)*0.5+0.5);\r\n}\r\n\r\n// Based on code by Inigo Quilez: https://iquilezles.org/articles/voronoilines/\r\nvoid CustomVoronoi_float(float2 UV, float AngleOffset, float CellDensity, out float DistFromCenter, out float DistFromEdge)\r\n{\r\n    int2 cell = floor(UV * CellDensity);\r\n    float2 posInCell = frac(UV * CellDensity);\r\n\r\n    DistFromCenter = 8.0f;\r\n    float2 closestOffset;\r\n\r\n    for(int y = -1; y <= 1; ++y)\r\n    {\r\n        for(int x = -1; x <= 1; ++x)\r\n        {\r\n            int2 cellToCheck = int2(x, y);\r\n            float2 cellOffset = float2(cellToCheck) - posInCell + randomVector(cell + cellToCheck, AngleOffset);\r\n\r\n            float distToPoint = dot(cellOffset, cellOffset);\r\n\r\n            if(distToPoint < DistFromCenter)\r\n            {\r\n                DistFromCenter = distToPoint;\r\n                closestOffset = cellOffset;\r\n            }\r\n        }\r\n    }\r\n\r\n    DistFromCenter = sqrt(DistFromCenter);\r\n\r\n    DistFromEdge = 8.0f;\r\n\r\n    for(int y = -1; y <= 1; ++y)\r\n    {\r\n        for(int x = -1; x <= 1; ++x)\r\n        {\r\n            int2 cellToCheck = int2(x, y);\r\n            float2 cellOffset = float2(cellToCheck) - posInCell + randomVector(cell + cellToCheck, AngleOffset);\r\n\r\n            float distToEdge = dot(0.5f * (closestOffset + cellOffset), normalize(cellOffset - closestOffset));\r\n\r\n            DistFromEdge = min(DistFromEdge, distToEdge);\r\n        }\r\n    }\r\n}"
}

